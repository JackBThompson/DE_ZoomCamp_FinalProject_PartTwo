##Objective: Template showing all required environment variables so anyone cloning the repo knows exactly what secrets to set.##

# Copy this file to .env and fill in your values. File .env is never committed to git.

# GCP
GOOGLE_APPLICATION_CREDENTIALS=gcp-key.json
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET=your-gcs-bucket-name
BIGQUERY_DATASET=nba_analytics
GCP_REGION=us-central1

# Airflow
AIRFLOW_UID=50000
AIRFLOW_GID=0

# Postgres (Airflow metadata DB)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow